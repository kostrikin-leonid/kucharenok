# PostgreSQL (local or Railway)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recipe_collection?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Optional: public app URL for Auth.js callbacks in production
# AUTH_URL="https://your-app.up.railway.app"

# Optional: AI recipe import (normalizes to Ukrainian). Vision needs a vision-capable model.
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# Cloudinary — recipe images (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
