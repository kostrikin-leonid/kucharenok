generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  admin
  member
}

enum MemberStatus {
  active
  invited
}

enum WeeklyPlanStatus {
  draft
  active
  archived
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
  prep
}

enum RecipeSourceType {
  manual
  ai_text
  ai_image
}

enum NutritionSource {
  manual
  ai_estimated
}

enum NutritionConfidence {
  low
  medium
  high
}

enum AIImportInputType {
  text
  image
}

enum AIImportStatus {
  pending
  completed
  failed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        HouseholdMember[]
  recipesAuthored    Recipe[]          @relation("RecipeAuthor")
  weeklyPlansCreated WeeklyPlan[]      @relation("WeeklyPlanCreator")
  aiImportJobs       AIImportJob[]
}

model Household {
  id               String   @id @default(cuid())
  name             String
  defaultServings  Int?     @default(4)
  dailyKcalGoal    Int?
  dailyProteinGoal Float?
  dailyFatGoal     Float?
  dailyCarbGoal    Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members       HouseholdMember[]
  categories    Category[]
  tags          Tag[]
  ingredients   Ingredient[]
  recipes       Recipe[]
  weeklyPlans   WeeklyPlan[]
  shoppingLists ShoppingList[]
  usageLogs     RecipeUsageLog[]
  aiImportJobs  AIImportJob[]
}

model HouseholdMember {
  id           String         @id @default(cuid())
  householdId  String
  userId       String?
  role         HouseholdRole
  status       MemberStatus   @default(active)
  inviteToken  String?        @unique
  invitedEmail String?
  createdAt    DateTime       @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
  @@index([inviteToken])
}

model Category {
  id          String   @id @default(cuid())
  householdId String
  name        String
  slug        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipes   Recipe[]

  @@unique([householdId, slug])
  @@index([householdId])
}

model Tag {
  id          String   @id @default(cuid())
  householdId String
  name        String
  slug        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household   Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipeTags  RecipeTag[]

  @@unique([householdId, slug])
  @@index([householdId])
}

model Ingredient {
  id                String   @id @default(cuid())
  householdId       String
  name              String
  slug              String
  shoppingCategory  String?
  defaultUnit       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  household         Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
  shoppingItems     ShoppingListItem[]

  @@unique([householdId, slug])
  @@index([householdId])
}

model Recipe {
  id                    String            @id @default(cuid())
  householdId           String
  authorId              String
  title                 String
  slug                  String
  summary               String?
  imageUrl              String?
  imagePublicId         String?
  categoryId            String?
  baseServings          Float             @default(4)
  prepTimeMinutes       Int?
  cookTimeMinutes       Int?
  totalTimeMinutes      Int?
  difficulty            String?
  instructionsText      String?           @db.Text
  instructionSteps      Json?
  kcalPerServing        Float?
  proteinPerServing     Float?
  fatPerServing         Float?
  carbsPerServing       Float?
  nutritionSource       NutritionSource?
  nutritionConfidence   NutritionConfidence?
  sourceType            RecipeSourceType  @default(manual)
  sourceRawText         String?           @db.Text
  isArchived            Boolean           @default(false)
  isFavorite            Boolean           @default(false)
  hiddenFromSuggestions Boolean           @default(false)
  isPreparation         Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  household    Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  author       User               @relation("RecipeAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  category     Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ingredients  RecipeIngredient[]
  recipeTags   RecipeTag[]
  planItems    WeeklyPlanItem[]
  usageLogs    RecipeUsageLog[]
  usedAsIngredientIn RecipeIngredient[] @relation("IngredientPreparation")

  @@unique([householdId, slug])
  @@index([householdId])
  @@index([categoryId])
  @@index([isArchived])
  @@index([isPreparation])
}

model RecipeIngredient {
  id                    String   @id @default(cuid())
  recipeId              String
  ingredientId          String?
  preparationRecipeId   String?
  customName            String?
  quantity              Float?
  unit                  String?
  note                  String?
  isToTaste             Boolean  @default(false)
  sortOrder             Int      @default(0)

  recipe              Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient          Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  preparationRecipe   Recipe?     @relation("IngredientPreparation", fields: [preparationRecipeId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([preparationRecipeId])
}

model RecipeTag {
  id       String @id @default(cuid())
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tagId])
  @@index([tagId])
}

model WeeklyPlan {
  id            String             @id @default(cuid())
  householdId   String
  weekStartDate DateTime           @db.Date
  weekEndDate   DateTime           @db.Date
  status        WeeklyPlanStatus   @default(draft)
  createdBy     String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  household Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  creator   User             @relation("WeeklyPlanCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  items     WeeklyPlanItem[]
  shoppingLists ShoppingList[]

  @@index([householdId, weekStartDate])
}

model WeeklyPlanItem {
  id           String   @id @default(cuid())
  weeklyPlanId String
  date         DateTime @db.Date
  mealType     MealType
  recipeId     String
  servings     Float    @default(4)
  note         String?
  sortOrder    Int      @default(0)

  weeklyPlan WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([weeklyPlanId, date])
  @@index([recipeId])
}

model ShoppingList {
  id            String   @id @default(cuid())
  householdId   String
  weeklyPlanId  String
  status        String?  @default("open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household  Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  weeklyPlan WeeklyPlan         @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  items      ShoppingListItem[]

  @@unique([weeklyPlanId])
  @@index([householdId])
}

model ShoppingListItem {
  id                   String   @id @default(cuid())
  shoppingListId       String
  ingredientId         String?
  customName           String?
  quantity             Float?
  unit                 String?
  isChecked            Boolean  @default(false)
  isManual             Boolean  @default(false)
  sourceBreakdownJson  Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  ingredient   Ingredient?  @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@index([shoppingListId])
}

model RecipeUsageLog {
  id               String   @id @default(cuid())
  householdId      String
  recipeId         String
  weeklyPlanId     String?
  weeklyPlanItemId String?
  usedOn           DateTime @db.Date
  createdAt        DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipe    Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([householdId, recipeId])
  @@index([recipeId, usedOn])
}

model AIImportJob {
  id               String            @id @default(cuid())
  householdId      String
  userId           String
  inputType        AIImportInputType
  rawInputText     String?           @db.Text
  imageUrl         String?
  parsedResultJson Json?
  status           AIImportStatus    @default(pending)
  createdAt        DateTime          @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId])
}
